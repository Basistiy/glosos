LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Secret auth for Gemini API key mode (optional if using Vertex AI mode instead).
GOOGLE_API_KEY=

# Backward-compatible alias for GOOGLE_API_KEY (optional).
GEMINI_API_KEY=

# Secret/service-account path for Google STT/TTS credentials (required).
GOOGLE_STT_CREDENTIALS_FILE=google-stt-service-account.json

# Optional for Vertex AI mode if you do not want to commit it in config/defaults.toml.
GOOGLE_CLOUD_PROJECT=
