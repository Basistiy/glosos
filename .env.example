LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Optional fallback if LIVEKIT_API_SECRET is unset.
# Must contain your LiveKit project secret (not a JWT room token).
LIVEKIT_TOKEN=
# Optional values used by run_token_agent.py when generating LIVEKIT_TOKEN.
LIVEKIT_ROOM=default-room
LIVEKIT_IDENTITY=token-agent
LIVEKIT_CLIENT_IDENTITY=human-test
LIVEKIT_TOKEN_TTL_SECONDS=3600

# Secret/service-account path used for Google STT/TTS and Vertex AI LLM (required).
GOOGLE_CREDENTIALS_FILE=google-service-account.json

# Optional: explicitly set Vertex project. If empty, inferred from service account.
GOOGLE_CLOUD_PROJECT=
