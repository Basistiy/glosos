LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Optional: if set, Gemini API key mode is used for LLM instead of Vertex AI.
GOOGLE_API_KEY=
# Backward-compatible alias for GOOGLE_API_KEY.
GEMINI_API_KEY=
GOOGLE_STT_CREDENTIALS_FILE=.config/keys/google-stt-service-account.json
GOOGLE_STT_LOCATION=eu
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GOOGLE_LLM_LOCATION=global
STT_MODEL=latest_long
# Required: single STT language only (examples: en-US, ru-RU).
STT_LANGUAGE=en-US
MIN_ENDPOINTING_DELAY=0.25
MAX_ENDPOINTING_DELAY=1.2
