LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Optional values used by run_token_agent.py when generating LIVEKIT_TOKEN.
LIVEKIT_ROOM=default-room
LIVEKIT_IDENTITY=token-agent
LIVEKIT_CLIENT_IDENTITY=human-test
LIVEKIT_TOKEN_TTL_SECONDS=3600

# Optional values used by run_token_agent_firebase.py.
# Non-secret Firebase values should be set in config/defaults.toml:
# - FIREBASE_WEB_API_KEY
# - FIREBASE_LIVEKIT_TOKEN_URL
# You can still override them here if needed.
FIREBASE_AUTH_USERNAME=agent@example.com
# Alternative to FIREBASE_AUTH_USERNAME:
# FIREBASE_AUTH_EMAIL=agent@example.com
FIREBASE_AUTH_PASSWORD=your_firebase_password
# Optional for callable getLivekitToken request.data.agentName
FIREBASE_AGENT_NAME=
# Optional: room/user to join; defaults to authenticated Firebase uid.
LIVEKIT_TARGET_UID=
# Optional: raw JSON body override sent to FIREBASE_LIVEKIT_TOKEN_URL.
# For Firebase callable functions, use {"data": {...}} format.
# Example: {"data":{"agentName":"my-agent"}}
FIREBASE_LIVEKIT_TOKEN_REQUEST_JSON=
